# vast.ai API key — https://cloud.vast.ai/account/
VAST_API_KEY=

# Public clone URL of THIS repo. The vast.ai instance will git-clone it on boot
# and run install.sh + serve.sh. Must be publicly readable (no creds in URL).
REPO_URL=https://github.com/cyohei9907/gemma4-vastai-ocr.git
REPO_BRANCH=main

# Optional: HF token. Gemma 4 is Apache 2.0 (no gating), but a token avoids
# anonymous rate limits when downloading ~60GB of weights.
HF_TOKEN=

# Default = largest dense Gemma 4. Needs >=80GB total VRAM.
# Cheaper alternatives:
#   google/gemma-4-e4b-it     (16GB VRAM, fast, lower OCR accuracy)
#   google/gemma-4-26b-a4b    (~40GB VRAM, MoE, near-31B quality)
MODEL_ID=google/gemma-4-31b-it
SERVE_PORT=8000
